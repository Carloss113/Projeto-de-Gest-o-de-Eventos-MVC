@model GestaoEventos.Models.Pedido

@{
    ViewData["Title"] = "Pedido Confirmado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 text-center">

            <div class="mb-4">
                <div style="width:80px;height:80px;border-radius:50%;background:#e1f5ee;
                            display:flex;align-items:center;justify-content:center;margin:0 auto;">
                    <i class="fas fa-check fa-2x" style="color:#1D9E75;"></i>
                </div>
            </div>

            <h2 class="fw-bold">Pagamento Confirmado!</h2>
            <p class="text-muted">
                Seu pedido <strong>#@Model.Id</strong> foi realizado com sucesso em
                @Model.DataPedido.ToString("dd/MM/yyyy 'às' HH:mm").
            </p>

            <div class="card border-0 shadow-sm mt-4 text-start">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Seus Ingressos</h5>

                    @foreach (var item in Model.Itens)
                    {
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                            <div>
                                <span class="fw-semibold">@item.NomeEvento</span><br />
                                <small class="text-muted">
                                    <span class="badge bg-light text-dark border me-1">@item.TipoIngresso</span>
                                    @item.Quantidade ingresso(s)
                                </small>
                            </div>
                            <span class="fw-bold text-primary">R$ @item.Subtotal.ToString("N2")</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between fw-bold fs-5 mt-3">
                        <span>Total pago</span>
                        <span class="text-primary">R$ @Model.Total.ToString("N2")</span>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4">
                    <i class="fas fa-home me-2"></i>Voltar ao início
                </a>
            </div>

        </div>
    </div>
</div>
