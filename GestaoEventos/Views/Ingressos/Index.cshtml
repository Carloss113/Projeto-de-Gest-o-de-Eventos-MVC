@model IEnumerable<GestaoEventos.Models.Ingresso>

@{
    ViewData["Title"] = "Gerenciar Ingressos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0"><i class="fas fa-ticket-alt me-2 text-primary"></i>Ingressos</h2>
        <small class="text-muted">Gerencie os ingressos cadastrados por evento</small>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill">
        <i class="fas fa-plus me-2"></i>Novo Ingresso
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div id="toast" style="position:fixed;top:20px;right:20px;z-index:9999;display:flex;align-items:center;gap:10px;
         background:#fff;border:1px solid #dee2e6;border-left:4px solid #1D9E75;
         border-radius:8px;padding:12px 16px;min-width:280px;">
        <span>@TempData["Sucesso"]</span>
        <button onclick="document.getElementById('toast').remove()"
                style="margin-left:auto;background:none;border:none;font-size:18px;cursor:pointer;color:#888;">×</button>
    </div>
    <script>setTimeout(() => document.getElementById('toast')?.remove(), 3500)</script>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Evento</th>
                    <th>Tipo</th>
                    <th>Preço</th>
                    <th>Disponíveis</th>
                    <th>Vendidos</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 align-middle fw-semibold">@item.Evento?.Titulo</td>
                        <td class="align-middle">
                            <span class="badge @(item.Tipo == GestaoEventos.Models.TipoIngresso.Inteira ? "bg-primary" :
                                                  item.Tipo == GestaoEventos.Models.TipoIngresso.MeiaEntrada ? "bg-warning text-dark" : "bg-secondary")">
                                @item.Tipo
                            </span>
                        </td>
                        <td class="align-middle">R$ @item.Preco.ToString("N2")</td>
                        <td class="align-middle">@item.QuantidadeDisponivel</td>
                        <td class="align-middle">@item.QuantidadeVendida</td>
                        <td class="align-middle">
                            @if (item.Ativo && item.Disponivel)
                            {
                                <span class="badge bg-success">Disponível</span>
                            }
                            else if (item.Ativo && !item.Disponivel)
                            {
                                <span class="badge bg-danger">Esgotado</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inativo</span>
                            }
                        </td>
                        <td class="text-end pe-4 align-middle">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-trash-alt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
