@model List<GestaoEventos.Models.CarrinhoItem>

@{
    ViewData["Title"] = "Meu Carrinho";
    var total = Model.Sum(i => i.Subtotal);
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2 text-primary"></i>Meu Carrinho</h2>

    @if (TempData["Sucesso"] != null)
    {
        <div id="toast" style="position:fixed;top:20px;right:20px;z-index:9999;display:flex;align-items:center;gap:10px;
             background:#fff;border:1px solid #dee2e6;border-left:4px solid #1D9E75;
             border-radius:8px;padding:12px 16px;min-width:280px;">
            <span>@TempData["Sucesso"]</span>
            <button onclick="document.getElementById('toast').remove()"
                    style="margin-left:auto;background:none;border:none;font-size:18px;cursor:pointer;color:#888;">×</button>
        </div>
        <script>setTimeout(() => document.getElementById('toast')?.remove(), 3500)</script>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Seu carrinho está vazio</h4>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill mt-2">
                <i class="fas fa-search me-2"></i>Ver Eventos
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- Itens -->
            <div class="col-md-8">
                @foreach (var item in Model)
                {
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body d-flex align-items-center gap-3">
                            <img src="@Url.Content("~/img/eventos/" + (item.ImagemUrl ?? "NoImage.png"))"
                                 style="width:80px;height:80px;object-fit:cover;border-radius:8px;">
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-1">@item.TituloEvento</h6>
                                <small class="text-muted">
                                    <i class="fas fa-calendar-day me-1"></i>
                                    @item.DataEvento.ToString("dd/MM/yyyy")
                                </small>
                                <div class="mt-1">
                                    <span class="badge bg-light text-dark border me-1">@item.TipoIngresso</span>
                                    <span class="text-muted small">@item.Quantidade x R$ @item.Preco.ToString("N2")</span>
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold text-primary fs-6">R$ @item.Subtotal.ToString("N2")</div>
                                <form asp-action="RemoverDoCarrinho" method="post" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ingressoId" value="@item.IngressoId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                        <i class="fas fa-trash-alt me-1"></i>Remover
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Resumo -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Resumo do Pedido</h5>

                        @foreach (var item in Model)
                        {
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>@item.TituloEvento (@item.TipoIngresso) x@item.Quantidade</span>
                                <span>R$ @item.Subtotal.ToString("N2")</span>
                            </div>
                        }

                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Total</span>
                            <span class="text-primary">R$ @total.ToString("N2")</span>
                        </div>

                        <a asp-action="Checkout" class="btn btn-primary w-100 rounded-pill mt-3">
                            <i class="fas fa-credit-card me-2"></i>Finalizar Compra
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 rounded-pill mt-2">
                            <i class="fas fa-plus me-2"></i>Adicionar mais eventos
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
