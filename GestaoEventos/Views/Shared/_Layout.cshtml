@* @using GestaoEventos.Helpers *@
@using GestaoEventos.Helpers
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GestaoEventos</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootswatch/5.3.2/flatly/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GestaoEventos.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/airbnb.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-main">
            <div class="container">
                <!-- Logo -->
                <a class="navbar-brand navbar-brand-logo" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-ticket-alt me-1"></i>Gestao<span>Eventos</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarMain" aria-expanded="false">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">

                    <!-- Links públicos — visíveis para todos -->
                    <ul class="navbar-nav me-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link-custom" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Início
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-custom" asp-controller="Home" asp-action="Sobre">
                                <i class="fas fa-circle-info me-1"></i>Sobre
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-custom" asp-controller="Home" asp-action="Contato">
                                <i class="fas fa-phone me-1"></i>Contato
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-custom" asp-controller="Home" asp-action="Privacy">
                                <i class="fas fa-lock me-1"></i>Privacidade
                            </a>
                        </li>
                    </ul>

                    <!-- Links admin — separados visualmente -->
                    @if (User.IsInRole("Admin") || User.IsInRole("Dono"))
                    {
                        <ul class="navbar-nav me-3 gap-1 align-items-center">
                            <div class="nav-divider d-none d-lg-block"></div>
                            <li class="nav-item">
                                <a class="nav-link-admin" asp-controller="Eventos" asp-action="Index">
                                    <i class="fas fa-calendar-alt me-1"></i>Eventos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link-admin" asp-controller="Categorias" asp-action="Index">
                                    <i class="fas fa-tags me-1"></i>Categorias
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link-admin" asp-controller="Locais" asp-action="Index">
                                    <i class="fas fa-map-marker-alt me-1"></i>Locais
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link-admin" asp-controller="Ingressos" asp-action="Index">
                                    <i class="fa-solid fa-ticket me-1"></i>Ingressos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link-admin" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-users-cog me-1"></i>Usuários
                                </a>
                            </li>
                            <div class="nav-divider d-none d-lg-block"></div>
                        </ul>
                    }

                    <!-- Área do usuário -->
                    <ul class="navbar-nav align-items-center gap-2">

                        @if (SignInManager.IsSignedIn(User))
                        {
                            var totalCarrinho = SessionHelper.TotalItens(Context.Session);
                            var nomeUsuario = UserManager.GetUserName(User) ?? "Usuário";
                            var inicial = nomeUsuario[0].ToString().ToUpper();

                           <!-- Carrinho -->
                            <li class="nav-item">
                                <a class="btn-carrinho" asp-controller="Ingressos" asp-action="Carrinho" title="Meu Carrinho">
                                    <i class="fas fa-shopping-cart"></i>
                                    @if (totalCarrinho > 0)
                                    {
                                        <span class="badge-count">@totalCarrinho</span>
                                    }
                                    else
                                    {
                                        <span class="d-none d-lg-inline" style="font-size:0.8rem;">Carrinho</span>
                                    }
                                </a>
                            </li> 

                            <!-- Usuário + Logout -->
                            <li class="nav-item d-flex align-items-center gap-2">
                                <div class="user-pill">
                                    <div class="user-avatar">@inicial</div>
                                    <span class="d-none d-lg-inline">@nomeUsuario</span>
                                </div>
                                <form asp-area="Identity" asp-page="/Account/Logout"
                                      asp-route-returnUrl="@Url.Action("Index", "Home")" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary rounded-pill"
                                            style="font-size:0.78rem; padding:4px 10px;">
                                        <i class="fas fa-sign-out-alt"></i>
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a asp-area="Identity" asp-page="/Account/Login"
                                       class="btn btn-outline-secondary btn-login rounded-pill me-1">
                                    Entrar
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-area="Identity" asp-page="/Account/Register"
                                       class="btn btn-success btn-login rounded-pill">
                                    <i class="fas fa-user-plus me-1"></i>Cadastrar
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- Conteúdo -->
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="footer-main">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="footer-brand mb-1">
                        <i class="fas fa-ticket-alt me-1"></i>Gestao<span>Eventos</span>
                    </div>
                    <small>Sua plataforma de eventos</small>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <small>
                        &copy; 2026 GestaoEventos &mdash;
                        <a asp-controller="Home" asp-action="Privacy">Privacidade</a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/pt.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>